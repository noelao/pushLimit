<!DOCTYPE html>
<html lang="id" data-theme="<%= typeof theme != 'undefined' ? theme : 'light' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title != 'undefined' ? title : 'pushLimit' %></title>
    <link rel="stylesheet" href="./media/css/style.css">
    <link rel="shortcut icon" href="./logoPushLimit.png" type="image/x-icon">

    <style>
        main {
            height: max-content;
            min-height: 100vh;
            position: relative;
            z-index: 1;
        }
        .background {
            position: sticky;
            display: flex;
            top: -3rem;
            left: 0;
            width: 100%;
            z-index: 0;

            align-items: end;
            .particles {
                position: absolute;
                bottom: -180px;
                right: 2rem;
                width: 3rem;
                opacity: .3;
                img {
                    width: 100%;
                    height: auto;
                }
            }
            .particles2 {
                position: absolute;
                bottom:calc(-6rem - 180px);
                right: 2rem;
                width: 3rem;
                opacity: .3;
                img {
                    width: 100%;
                    height: auto;
                }
            }
            .particles3 {
                position: absolute;
                bottom:calc(-3rem - 180px);
                right: 2rem;
                width: 3rem;
                opacity: .3;
                img {
                    width: 100%;
                    height: auto;
                }
            }
            .particles4 {
                position: absolute;
                bottom:calc(-12rem - 180px);
                left: -18vw;
                width: 82vw;
                opacity: .6;
                img {
                    width: 100%;
                    height: auto;
                }
            }
        }

        

    </style>
</head>
<body>
    <%- include('../partials/nav') %>
    <div class="background">
        <div class="particles">
            <img class="png-icon" src="./media/images/particles/2.png" alt="">
        </div>
        <div class="particles2">
            <img class="png-icon" src="./media/images/particles/3.png" alt="">
        </div>
        <div class="particles3">
            <img class="png-icon" src="./media/images/particles/4.png" alt="">
        </div>
        
        <div class="particles4">
            <img class="png-icon" src="./media/images/pedang.png" alt="">
        </div>
    </div>
    <main>
        <%- body %> 
    </main>

    <!-- Partials footer -->
    <%- include('../partials/footer') %>

</body>
</html>