<style>
.navbar {
    position: sticky;
    top: .5rem;

    width: 100%;
    padding: 0 1.5rem;

    
    z-index: 10;
    height: auto;
    transition: padding .3s ease;
    .iniNav {
        width: 100%;
        border-radius: 1.7rem;
        overflow: hidden;

        
        .iniWarnaNav {
            width: 100%;

            --tw-backdrop-blur: blur(24px);
            backdrop-filter: var(--tw-backdrop-blur);
            background-color: var(--nav);

            .atas {
                height: 0;
                width: 100%;
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 0;
                
                position: relative;
                transition: height .3s ease, opacity .3s ease;
                .garis {
                    background-color: #ababab;
                    opacity: .6;
                    width: 90%;
                    position: absolute;
                    bottom: 0;
                    height: 2px;
                }
            }
            .bawah {
                height: 3.4rem;
                width: 100%;

                display: flex;
                justify-content: space-between;
                padding: .7rem 1.5rem;
                .logo {
                    height: 100%;
                    aspect-ratio: 1;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    img {
                        height: 130%;
                    }
                }
                .navMenu {
                    padding: .5rem;
                    height: 100%;
                    aspect-ratio: 1;
                    display: flex;
                    flex-direction: column;
                    justify-content: space-evenly;
                    span {
                        width: 100%;
                        height: 3px;
                        background-color: var(--gelap);
                        transition: transform .3s ease;
                    }
                }
            }
        }
    }
}

.kepencet {
    padding: 0 .5rem;
    .iniNav {
        .iniWarnaNav {
            .atas {
                height: 5.5rem;
                opacity: 1;
            }
            .bawah {
                .navMenu {
                    span:nth-child(1) {
                        transform: rotate(30deg);
                    }
                    span:nth-child(2) {
                        transform: rotate(30deg);
                    }
                }
            }
        }
    }
}
</style>

<div class="navbar">
    <div class="iniNav">
        <div class="iniWarnaNav">

            <div class="atas">
                <button id="theme-toggle" class="btn-theme">
                    Ganti Tema 🌓
                </button>

                <div class="garis"></div>
            </div>
            <div class="bawah">
                <a href="/" class="logo">
                    <img class="png-icon" src="./logoPushLimit.png" alt="">
                </a>
                <div class="navMenu">
                    <span></span>
                    <span></span>
                </div>
            </div>
            
        </div>
    </div>
</div>

<script>
    const navMenu = document.querySelector(".iniWarnaNav .navMenu")
    navMenu.addEventListener("click", function(){
        navMenu.parentElement.parentElement.parentElement.parentElement.classList.toggle("kepencet");
    })
</script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('theme-toggle');
        const htmlElement = document.documentElement; 

        // Good practice: Cek apakah tombol benar-benar ada di DOM 
        // untuk mencegah error jika suatu saat tombol disembunyikan/dihapus
        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                // Cek tema saat ini, fallback ke 'light' jika kosong
                let currentTheme = htmlElement.getAttribute('data-theme') || 'light';
                let newTheme = currentTheme === 'light' ? 'dark' : 'light';

                // 1. Ubah tampilan secara langsung
                htmlElement.setAttribute('data-theme', newTheme);

                // 2. Simpan ke Cookie
                document.cookie = `theme=${newTheme}; path=/; max-age=31536000; SameSite=Lax`;
            });
        }
    });
</script>

